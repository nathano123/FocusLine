# Copy this to `.env` and fill in your PostHog Project API key.
# `.env` is gitignored — never commit your key.
#
# Both the landing page (/) and the running app (/app) share the same SPA,
# so this single key instruments both surfaces.

VITE_POSTHOG_KEY=phc_your_project_key_here
VITE_POSTHOG_HOST=https://eu.i.posthog.com
