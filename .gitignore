# Web
web/node_modules
web/dist
web/dist-ssr
web/.vite
web/*.local

# Env files — never commit your PostHog key
web/.env
web/.env.local
web/.env.*.local

# Generated icons (regenerated by `npm run icons`)
web/public/icon-*.png
web/public/apple-touch-icon.png
web/public/og-image.png

# Xcode — user-specific state, never check in
**/xcuserdata/
**/*.xcuserstate
**/*.xcuserdatad/
**/UserInterfaceState.xcuserstate
**/xcschememanagement.plist

# Xcode — derived build artifacts
DerivedData/
build/
**/build/
**/DerivedData/

# macOS junk
.DS_Store
.AppleDouble
.LSOverride
Icon?

# Claude local config
**/.claude/

# Tauri build artifacts
web/src-tauri/target/
web/src-tauri/gen/

# Compiled Swift binary (rebuilt by swiftc; the .dmg in web/public is the artifact we ship)
macos/FocusLine

# TS build info
**/*.tsbuildinfo

# Logs
*.log
